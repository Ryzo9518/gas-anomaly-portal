# Client mode — first-time client state, no history, upload intake mode.
# Use when setting up the portal for a real client's first audit.
#
# Before running in this mode, update reports.fixture.clean.ts:
#   1. CLIENT_INFO.name → real client name
#   2. Report healthScore, leakageEstimate, leakageRecoverable, risks
#   3. FINDINGS_CURRENT → actual audit output
# Run: PORT=5199 npm run dev:client
VITE_FIXTURE=clean

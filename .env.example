# GAS BP Portal — environment template
# Copy this file to `.env.local` (gitignored) and fill local values.
#
# Adapter selector. Defaults to "mock" if unset. Set to "bff" to route
# through the live HTTP adapters once they replace the NotImplementedError
# stubs in src/adapters/bff/*.
VITE_ADAPTER=mock

# Base URL of the GAS Portal backend (Phase 1 portal app). Used by
# src/lib/portalApi.ts for Commercial Overlay calls:
#   GET  /gas/portal/bp/lead/<id>/overlay/latest
#   POST /gas/portal/bp/lead/<id>/overlay
# Trailing slash is optional and stripped by portalApi.
VITE_PORTAL_BASE_URL=http://localhost:5000
